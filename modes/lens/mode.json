{
  "name": "lens",
  "description": "Explain a concept through a hobbyist's frame of reference, selected by the runtime via --lens.",
  "version": 1,
  "phases": [
    {
      "name": "main",
      "kind": "main",
      "prompt": "prompts/main.md"
    },
    {
      "name": "critic",
      "kind": "critic",
      "prompt": "prompts/critic.md"
    },
    {
      "name": "revision",
      "kind": "revision",
      "prompt": "prompts/revision.md"
    }
  ],
  "outputContract": {
    "requiredHeadings": [
      "## The Concept",
      "## The Lens",
      "## The Mapping",
      "## Where It Breaks Down",
      "## Plain Translation"
    ],
    "minimumLength": 200
  }
}
